    end

    D1 --> OUT([To Part 2:\nSTL Decomposition])
    D2 --> OUT

    style ING fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    style PRE fill:#ede9fe,stroke:#7c3aed,color:#2e1065
