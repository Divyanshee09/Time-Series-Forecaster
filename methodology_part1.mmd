flowchart LR
    A([🗂️ Raw Time\nSeries Data]) --> B

    subgraph ING ["① Data Ingestion & Validation"]
        B[Schema Check]
        B --> B1[Missing Value\nDetection]
        B1 --> B2[Frequency\nInference]
    end

    B2 --> C

    subgraph PRE ["② Adaptive Preprocessing"]
        C{Preprocessing\nMode?}
