\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Rolling-origin diagnostic pass rates after gated refitting. LB = Ljung-Box ($p{>}0.05$); ACF = fraction of 20 lags within 95\% CI ($\leq 5\%$ exceedances); ARCH = ARCH-LM test ($p{>}0.05$ indicates no volatility clustering; pass means SARIMA is adequate for the conditional variance). ``LB 95\%~CI'' = Wilson binomial confidence interval ($n{=}4$ trials per series). ``LB\,(NG)'' = LB pass rate for the no-gating ablation, quantifying baseline residual quality before any refitting.}}{13}{table.5}\protected@file@percent }
\newlabel{tab:diag}{{5}{13}{Rolling-origin diagnostic pass rates after gated refitting. LB = Ljung-Box ($p{>}0.05$); ACF = fraction of 20 lags within 95\% CI ($\leq 5\%$ exceedances); ARCH = ARCH-LM test ($p{>}0.05$ indicates no volatility clustering; pass means SARIMA is adequate for the conditional variance). ``LB 95\%~CI'' = Wilson binomial confidence interval ($n{=}4$ trials per series). ``LB\,(NG)'' = LB pass rate for the no-gating ablation, quantifying baseline residual quality before any refitting}{table.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Diagnostic results across four rolling origins per series. Blue: Ljung-Box pass rate; green: ACF exceedance pass rate; red: ARCH-LM failure rate (indicating volatility clustering). ACF passes at 100\% everywhere; Bitcoin and COVID-19 exhibit 100\% ARCH failure, confirming heteroskedastic structure beyond SARIMA's scope.}}{14}{figure.5}\protected@file@percent }
\newlabel{fig:diag_passes}{{5}{14}{Diagnostic results across four rolling origins per series. Blue: Ljung-Box pass rate; green: ACF exceedance pass rate; red: ARCH-LM failure rate (indicating volatility clustering). ACF passes at 100\% everywhere; Bitcoin and COVID-19 exhibit 100\% ARCH failure, confirming heteroskedastic structure beyond SARIMA's scope}{figure.5}{}}
