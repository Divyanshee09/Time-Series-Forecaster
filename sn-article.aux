\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Mean RMSE~$\pm $~std across 4 rolling origins. FS\,L = DGSAR Light; FS\,F = Full preprocessing. $\Delta $P = relative change vs Prophet (positive favours FS). FS\,NG (no-gating ablation) equals FS\,L on all series and is omitted. Bold = best model per series.}}{10}{table.3}\protected@file@percent }
\newlabel{tab:perf}{{3}{10}{Mean RMSE~$\pm $~std across 4 rolling origins. FS\,L = DGSAR Light; FS\,F = Full preprocessing. $\Delta $P = relative change vs Prophet (positive favours FS). FS\,NG (no-gating ablation) equals FS\,L on all series and is omitted. Bold = best model per series}{table.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Mean MASE across 4 rolling origins (scale-free; $<1$ beats seasonal na\"{i}ve baseline). MASE = MAE / mean in-sample seasonal-na\"{i}ve MAE; enables direct cross-series comparison. FS\,NG $=$ FS\,L MASE on all five series, confirming gating does not degrade point accuracy. Bold = best model per row. Win rates (MASE, DGSAR Light): \textbf  {5/5 vs Prophet}; 3/5 vs ETS; 3/5 vs Theta; 4/5 vs SNav.}}{11}{table.4}\protected@file@percent }
\newlabel{tab:mase}{{4}{11}{Mean MASE across 4 rolling origins (scale-free; $<1$ beats seasonal na\"{i}ve baseline). MASE = MAE / mean in-sample seasonal-na\"{i}ve MAE; enables direct cross-series comparison. FS\,NG $=$ FS\,L MASE on all five series, confirming gating does not degrade point accuracy. Bold = best model per row. Win rates (MASE, DGSAR Light): \textbf {5/5 vs Prophet}; 3/5 vs ETS; 3/5 vs Theta; 4/5 vs SNav}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Relative RMSE comparison across all five series, normalised to DGSAR Light = 1.0. Values below the dashed line indicate the baseline outperforms DGSAR; values above indicate DGSAR is superior.}}{11}{figure.2}\protected@file@percent }
\newlabel{fig:rmse_comp}{{2}{11}{Relative RMSE comparison across all five series, normalised to DGSAR Light = 1.0. Values below the dashed line indicate the baseline outperforms DGSAR; values above indicate DGSAR is superior}{figure.2}{}}
